# Ignorar el entorno virtual (es pesadísimo y cada quien crea el suyo)
env/
venv/

# Ignorar archivos de caché de Python
__pycache__/
*.pyc

# ¡SÚPER IMPORTANTE! Ignorar las bases de datos biométricas por privacidad
*.pkl
shogun_db.pkl
shogun_invalidos.pkl

# --- AGREGADOS NINJA ---

# Ignorar archivos ocultos de configuración de tu editor de código (VS Code, etc.)
.vscode/
.idea/

# Ignorar la basura visual que genera el sistema operativo
Thumbs.db
Desktop.ini

# Ignorar variables de entorno (por si en el futuro le metes contraseñas o APIs)
.env